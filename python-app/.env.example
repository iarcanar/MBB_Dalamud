# MBB Dalamud v1.0.0 - API Keys Configuration Template
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: Google Gemini API Key
# =============================================================================
# Get your FREE API key from: https://ai.google.dev/
# 1. Visit https://ai.google.dev/
# 2. Click "Get API Key" → "Create API Key"
# 3. Copy the key (starts with AIza...)
# 4. Paste it below (no quotes needed)

GEMINI_API_KEY=your_api_key_here

# =============================================================================
# OPTIONAL: Application Settings
# =============================================================================

# Debug mode (true/false)
MBB_DEBUG=false

# Log level (debug/info/warning/error)
MBB_LOG_LEVEL=info

# Skip system checks on startup (0/1)
MBB_SKIP_CHECKS=0

# =============================================================================
# NOTES
# =============================================================================
# - DO NOT commit .env file to git (it contains your API keys)
# - Keep your API keys secure and private
# - Gemini API free tier: 15 requests/min, 1M tokens/day
