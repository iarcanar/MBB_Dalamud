# =============================================================================
# MBB Dalamud - Git Ignore Rules
# =============================================================================

# Environment variables and secrets
.env
*.env
!.env.example
python-app/.env

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
ENV/
env/
.venv

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Build artifacts
build/
dist/
*.egg-info/
*.egg

# PyInstaller
*.spec.bak
*.manifest
*.spec.swp

# C# build artifacts
bin/
obj/
*.user
*.suo
*.cache
*.dll
*.exe
*.pdb
*.cache

# Logs
*.log
logs/
*.log.*

# User data
settings.json
font_settings.json
last_directory.txt

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~

# Database files
*.db
*.sqlite
*.sqlite3

# Release packages
*.zip
!plugins/**/latest.zip
*.rar
*.7z
*.tar.gz

# Testing
.pytest_cache/
.coverage
htmlcov/

# Documentation builds
docs/_build/

# Claude Code configuration (local only)
.claude/
.claude/**/*

# Dev session notes (temporary, not part of source)
ASSET_DEBUG_BUILD05.md
BUILD06_FIX_SUMMARY.md
BUILD07_FINAL_FIX.md
BUILD09_CLEANUP.md
BUILD_FIXES_SUMMARY.md
BUILD_NOTES_v1.7.0.md
CLOSE_FIX_SUMMARY.md
DEPRECATED_FEATURES.md
OFFICIAL_REPO_REQUIREMENTS.md
PROJECT_COMPLETE.md
PUSH_CHECKLIST.md
RELEASE_v1.7.0.md
REPOSITORY_STATUS.md
WEBSITE_SKILL.md

# Backups and legacy code (local only)
python-app/backups/
python-app/Legacy/

# Adobe / design source files
*.ai
*.psd

# Windows artifacts
nul
